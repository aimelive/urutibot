DATABASE_URL=jdbc:postgresql://<neon-host>/<db>?sslmode=require&channel_binding=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=replace-with-neon-password

# JWT
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-base64-string
JWT_EXPIRATION_MS=31536000000

# Admin bootstrap — seeded once at startup when no user with this email exists.
# Provide the plaintext password; the app hashes it with BCrypt before persisting.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_FULL_NAME=Administrator

# Anthropic (LangChain4J)
ANTHROPIC_API_KEY=sk-ant-...

# Mail (Gmail SMTP)
APP_EMAIL_USERNAME=your-email@gmail.com
APP_EMAIL_PASSWORD=your-gmail-app-password

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173